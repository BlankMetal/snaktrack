{
  "name": "snack-approval-portal",
  "version": "0.3.7",
  "private": true,
  "description": "Internal snack request approval dashboard for office operations.",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "generate:data": "node scripts/generate-snack-requests.js",
    "build": "node scripts/seed-demo-data.js && vite build",
    "test": "node scripts/seed-demo-data.js && node scripts/check-snack-rules.js",
    "check": "npm test",
    "test:snaktrack": "node agents/publish/publish-snaktrack.js --dry-run"
  },
  "devDependencies": {
    "vite": "^6.4.2"
  }
}
